# Visuals
theme = Snutkaffe
#theme = TokyoNight
#theme = Fotklanen
#theme = Aizen Dark
window-padding-x = 10,4
#window-decoration = none
#background-opacity = 0.75

# Font configuration
font-family = JetBrainsMono Nerd Font
#font-size = 14
font-size = 12
      
# Cursor configuration
mouse-hide-while-typing = true
cursor-style-blink = true
#cursor-style = block
shell-integration-features = no-cursor

# Binds
keybind = ctrl+t=new_split:right
keybind = ctrl+g=new_split:down
keybind = ctrl+right=goto_split:right
keybind = ctrl+left=goto_split:left
keybind = ctrl+up=goto_split:up
keybind = ctrl+down=goto_split:down
keybind = ctrl+w=close_surface
