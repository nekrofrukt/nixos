#!/usr/bin/env python3

import subprocess

ROFI = ["rofi", "-dmenu", "-i", "-p", "󰂯"]

def bt(cmd):
    return subprocess.run(
        ["bluetoothctl"] + cmd,
        capture_output=True,
        text=True
    ).stdout.strip()


def paired_devices():
    devices = []
    for line in bt(["devices"]).splitlines():
        parts = line.split(" ", 2)
        if len(parts) >= 3:
            mac = parts[1]
            name = parts[2]
            info = bt(["info", mac])
            connected = "Connected: yes" in info
            icon = "" if not connected else "󰂱"
            devices.append((f"{icon} {name}", mac, connected))
    return devices


def menu():
    devices = paired_devices()

    entries = []
    mapping = {}

    for label, mac, connected in devices:
        entries.append(label)
        mapping[label] = (mac, connected)

    entries += [
        "󰓦 Scan",
        " Toggle Bluetooth"
    ]

    result = subprocess.run(
        ROFI,
        input="\n".join(entries),
        capture_output=True,
        text=True
    ).stdout.strip()

    return result, mapping


def main():
    choice, mapping = menu()

    if not choice:
        return

    if choice == "󰓦 Scan":
        subprocess.run(["bluetoothctl", "--timeout", "5", "scan", "on"])
        return

    if choice == " Toggle Bluetooth":
        state = bt(["show"])
        if "Powered: yes" in state:
            bt(["power", "off"])
        else:
            bt(["power", "on"])
        return

    if choice in mapping:
        mac, connected = mapping[choice]
        if connected:
            bt(["disconnect", mac])
        else:
            bt(["connect", mac])


if __name__ == "__main__":
    main()
