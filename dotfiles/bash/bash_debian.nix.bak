{ config, pkgs, ... }:

{
  programs.bash = {
    enable = true;

    initExtra = ''
      eval "$(starship init bash)"

      alias btw='echo i use nix on debian btw'

      alias ll='ls -l'
      alias la='ls -A'
      alias update='sudo nala update'
      alias upgrade='sudo nala upgrade'
      alias system_upgrade='sudo nala update; sudo nala upgrade'

      alias cd_nixos='cd ~/src/nixos'
      alias debian_switch='home-manager switch -f ~/src/nixos/hosts/debian/home.nix'
    '';
  };
}
